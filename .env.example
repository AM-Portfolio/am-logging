# AM Logging Service - Local Configuration
# Copy this file to .env and update the values

# Redis Configuration (Used for async log buffering)
REDIS_URL=redis://localhost:6379/0

# MongoDB Configuration (Used for Business & Audit log persistence)
MONGO_URL=mongodb://localhost:27017

# Loki Configuration (Optional - for technical log aggregation)
LOKI_URL=http://localhost:3100/loki/api/v1/push

# Environment Name
ENVIRONMENT=local

# Service Port
PORT=8004
